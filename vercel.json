{
    "version": 2,
    "builds": [
        {
            "src": "**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/mastrouh_qa_prep",
            "dest": "/mastrouh_qa_prep.html"
        },
        {
            "src": "/mastrouh_qa",
            "dest": "/mastrouh_qa.html"
        },
        {
            "src": "/",
            "dest": "/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}